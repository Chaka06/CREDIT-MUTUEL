# ════════════════════════════════════════════════════════════════════════════
#  Crédit Mutuel — Variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs
# ════════════════════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────────────────────
# Génère une clé : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_generate_a_secret_key

# True en dev uniquement — False obligatoire en production
DEBUG=False

# Ton domaine Vercel et/ou domaine custom
ALLOWED_HOSTS=ton-projet.vercel.app,www.ton-domaine.com

# URL complète du site (utilisée dans les emails)
SITE_URL=https://ton-projet.vercel.app


# ── Supabase — Base de données PostgreSQL ───────────────────────────────────
# Récupère ces infos dans : Supabase > Project Settings > Database
# Utilise le "Transaction pooler" (port 6543) pour Vercel (serverless)
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DB_PASSWORD=ton-mot-de-passe-supabase
DB_HOST=aws-0-eu-west-3.pooler.supabase.com
DB_PORT=6543


# ── Supabase — Stockage fichiers (logos, favicons, images OG) ───────────────
# Récupère ces infos dans : Supabase > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
STORAGE_BUCKET_NAME=media


# ── Brevo — Emails transactionnels ──────────────────────────────────────────
# Paramètres SMTP disponibles dans : Brevo > Senders & IP > SMTP & API
# IMPORTANT : le domaine d'envoi doit être vérifié dans Brevo (Senders > Domains)
BREVO_SMTP_LOGIN=ton-login@mutuelspace.com
BREVO_SMTP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=no_reply@mutuelspace.com


# ── Chiffrement Fernet ───────────────────────────────────────────────────────
# Génère une clé : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key
